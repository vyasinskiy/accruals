{
  "name": "accruals-accountant",
  "version": "0.1.0",
  "private": true,
  "description": "Database and RabbitMQ processor for accruals",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/main.js",
    "start:prod": "npm run prisma:migrate && node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy || true",
    "prisma:migrate-dev": "prisma migrate dev",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^6.6.0",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^1.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@prisma/client": "6.6.0",
    "@types/cron": "^2.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "prisma": "6.6.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

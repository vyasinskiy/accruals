generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Apartment {
  id            Int       @id @default(autoincrement())
  externalId    String    @unique @map("external_id")
  address       String?
  organization  String?
  rawJson       String?   @map("raw_json")
  firstSeenAt   DateTime  @map("first_seen_at")
  lastSeenAt    DateTime  @map("last_seen_at")
  accounts      Account[]
  tenants       Tenant[]

  @@index([address], map: "idx_apartments_address")
  @@index([organization], map: "idx_apartments_organization")
  @@map("apartments")
}

model User {
  id              Int            @id @default(autoincrement())
  name            String?
  role            String         @default("tenant") // admin, tenant
  createdAt       DateTime       @default(now()) @map("created_at")

  tenantProfile   Tenant?
  payments        Payment[]

  @@map("users")
}

model Tenant {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique @map("user_id")
  apartmentId     Int?      @map("apartment_id")
  rentPaymentDay  Int?      @map("rent_payment_day")
  rentAmount      Decimal?  @db.Decimal(10, 2) @map("rent_amount")
  status          String    @default("pending") // pending, active, rejected
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  apartment       Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@map("tenants")
}

model Account {
  id            Int       @id @default(autoincrement())
  externalId    String    @unique @map("external_id")
  apartmentId   Int       @map("apartment_id")
  accountNumber String?   @map("account_number")
  accountLabel  String?   @map("account_label")
  customLabel   String?   @map("custom_label")
  balance       Decimal?  @db.Decimal(10, 2)
  rawJson       String?   @map("raw_json")
  firstSeenAt         DateTime  @map("first_seen_at")
  lastSeenAt          DateTime  @map("last_seen_at")
  meterSubmissionDay  Int       @default(20) @map("meter_submission_day")
  apartment           Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  accruals            Accrual[]
  invoices            Invoice[]
  meterEvents         MeterSubmissionEvent[]

  @@index([accountNumber], map: "idx_accounts_number")
  @@map("accounts")
}

model Accrual {
  id                Int       @id @default(autoincrement())
  accountId         Int       @map("account_id")
  accountExternalId String    @map("account_external_id")
  periodId          String    @map("period_id")
  periodLabel       String    @map("period_label")
  amountText        String?   @map("amount_text")
  statusText        String?   @map("status_text")
  sourceUrl         String?   @map("source_url")
  rawJson           String?   @map("raw_json")
  firstSeenAt       DateTime  @map("first_seen_at")
  lastSeenAt    DateTime  @map("last_seen_at")
  account           Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountExternalId, periodId])
  @@index([accountId, periodLabel], map: "idx_accruals_account_period")
  @@map("accruals")
}

model Invoice {
  id                Int       @id @default(autoincrement())
  accountId         Int       @map("account_id")
  accountExternalId String    @map("account_external_id")
  periodId          String    @map("period_id")
  periodLabel       String    @map("period_label")
  amount            Decimal?  @db.Decimal(10, 2)
  invoiceUrl        String?   @map("invoice_url")
  utilitiesUrl      String?   @map("utilities_url")
  localFilePath     String?   @map("local_file_path")
  available         Boolean   @default(false)
  uploadedToS3      Boolean   @default(false) @map("uploaded_to_s3")
  rawJson           String?   @map("raw_json")
  firstSeenAt       DateTime  @map("first_seen_at")
  lastSeenAt        DateTime  @map("last_seen_at")
  account           Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountExternalId, periodId])
  @@index([accountId, periodLabel], map: "idx_invoices_account_period")
  @@map("invoices")
}

model Payment {
  // existing fields remain unchanged
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  userName         String?  @map("user_name")
  amount           Decimal  @db.Decimal(10, 2)
  receiptPhotoId   String?  @map("receipt_photo_id")
  status           String   @default("unconfirmed") // unconfirmed, confirmed, rejected
  createdAt        DateTime @default(now()) @map("created_at")
  confirmedAt      DateTime? @map("confirmed_at")
  confirmedBy      BigInt?  @map("confirmed_by")
  comment          String?

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model MeterSubmissionEvent {
  id               Int       @id @default(autoincrement())
  accountId        Int       @map("account_id")
  periodId         String    @map("period_id")
  periodLabel      String    @map("period_label")
  targetDate       DateTime  @map("target_date")
  notificationSent Boolean   @default(false) @map("notification_sent")
  status           String    @default("PENDING")
  receivedAt       DateTime? @map("received_at")
  readingsValue    String?   @map("readings_value")
  submittedAt      DateTime? @map("submitted_at")
  lastReminderSent DateTime? @map("last_reminder_sent")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  account          Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, periodId])
  @@map("meter_submission_events")
}


model Event {
  id        Int      @id @default(autoincrement())
  type      String
  date      DateTime
  status    String   @default("pending")
  details   String?
  createdAt DateTime @default(now())
}

{
  "name": "kvartplata-watcher",
  "version": "0.2.0",
  "private": true,
  "description": "Local NestJS backend for kvartplata.online session-based scraping and API access",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "npm run build && node dist/main.js",
    "start:prod": "npm run prisma:migrate && node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "bootstrap": "tsx src/scripts/bootstrap.ts",
    "scan": "tsx src/scripts/scan.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "test": "jest",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers npx playwright install chromium",
    "deploy": "./scripts/deploy.sh",
    "docker:up": "docker compose up -d",
    "docker:rebuild": "docker compose up --build app -d",
    "docker:down": "docker compose down",
    "docker:bootstrap": "docker exec -it kvartplata-watcher-app npm run bootstrap",
    "docker:scan": "docker exec -it kvartplata-watcher-app npm run scan"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.6.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.6.1",
    "playwright": "1.59.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.6.0",
    "jest": "^29.7.0",
    "prisma": "6.6.0",
    "@prisma/client": "6.6.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}

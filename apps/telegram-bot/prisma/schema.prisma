generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("TELEGRAM_BOT_DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  telegramId      BigInt    @unique @map("telegram_id")
  username        String?
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  role            String    @default("tenant") // admin, tenant
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("users")
}

model PublicationChannel {
  id        Int           @id @default(autoincrement())
  chatId    String        @unique @map("chat_id")
  name      String?
  createdAt DateTime      @default(now()) @map("created_at")

  publications Publication[]

  @@map("publication_channels")
}

model Publication {
  id          Int                @id @default(autoincrement())
  invoiceId   Int                @map("invoice_id")
  publishedAt DateTime           @default(now()) @map("published_at")
  channelId   Int                @map("channel_id")
  channel     PublicationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, channelId])
  @@map("publications")
}


{
  "name": "accruals-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot for accruals notifications",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/main.js",
    "start:prod": "npm run prisma:migrate && node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.6.0",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.5",
    "dotenv": "^16.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "prisma": "6.6.0",
    "@prisma/client": "6.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}

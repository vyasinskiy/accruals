{
  "name": "kvartplata-watcher",
  "version": "0.1.0",
  "private": true,
  "description": "Manual-login Playwright watcher for kvartplata.online receipts and charges",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bootstrap": "tsx src/cli.ts bootstrap",
    "scan": "tsx src/cli.ts scan",
    "notify": "tsx src/cli.ts notify",
    "run": "tsx src/cli.ts run",
    "scheduler": "tsx src/cli.ts scheduler",
    "db:init": "tsx src/cli.ts db:init"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "playwright": "^1.54.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}

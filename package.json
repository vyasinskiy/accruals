{
  "name": "kvartplata-watcher",
  "version": "0.1.0",
  "private": true,
  "description": "Manual-login Playwright watcher for kvartplata.online receipts and charges",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bootstrap": "tsx src/cli.ts bootstrap",
    "scan": "tsx src/cli.ts scan",
    "notify": "tsx src/cli.ts notify",
    "run": "tsx src/cli.ts run",
    "scheduler": "tsx src/cli.ts scheduler",
    "db:init": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "dotenv": "^16.6.1",
    "playwright": "^1.54.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "prisma": "^6.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}

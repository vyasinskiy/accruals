{
  "name": "kvartplata-watcher",
  "version": "0.2.0",
  "private": true,
  "description": "Local NestJS backend for kvartplata.online session-based scraping and API access",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "npm run build && node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "bootstrap": "tsx src/scripts/bootstrap.ts",
    "scan": "tsx src/scripts/scan.ts",
    "db:init": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "deploy": "./scripts/deploy.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "playwright": "^1.54.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "prisma": "^6.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}

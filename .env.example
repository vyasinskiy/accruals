# Base app settings
TZ=America/Los_Angeles
APP_URL=https://kvartplata.online/
APP_TIMEZONE=America/Los_Angeles
DATA_DIR=./data
STORAGE_STATE_PATH=./data/storage-state.json
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kvartplata_watcher?schema=public
HEADLESS=true
LOG_LEVEL=info

# Session / login detection
LOGIN_URL=https://kvartplata.online/
LOGIN_REQUIRED_TEXT=Войти,Авторизация,Капча,CAPTCHA,Личный кабинет
ACCOUNT_READY_TEXT=Начисления,Квитанция,Лицевой счет,Личный кабинет
SESSION_REQUIRED_KEYWORDS=войти,авторизация,captcha,капча

# Adapter defaults for kvartplata.online.
# Override these if the site DOM differs from the assumptions below.
ACCOUNT_PAGE_URL=
CHARGES_PAGE_URL=
CHARGES_TAB_SELECTOR=text=/Начисления|Платежи|Квитанции/i
ACCOUNT_CARD_SELECTOR=[data-account], .account-card, .abonent-item, .ls-item
ACCOUNT_NAME_SELECTOR=.account-card__title, .account-name, .abonent-item__title, .title
ACCOUNT_ID_SELECTOR=.account-card__number, .ls-number, .account-number, .subtitle
ACCOUNT_LINK_SELECTOR=a
ROW_SELECTOR=table tbody tr, .charges-table tbody tr, .receipt-row, .payment-row
MONTH_SELECTOR=[data-month], .month, td:nth-child(1)
AMOUNT_SELECTOR=[data-amount], .amount, td:nth-child(2)
STATUS_SELECTOR=[data-status], .status, td:nth-child(3)
RECEIPT_BUTTON_SELECTOR=a:has-text("Квитанция"), button:has-text("Квитанция"), [title*="Квитанц"]
NEXT_PAGE_SELECTOR=
WAIT_AFTER_LOGIN_MS=3000
WAIT_AFTER_NAV_MS=1500

# Optional receipt PDF download support
DOWNLOAD_RECEIPTS=false
RECEIPT_DOWNLOAD_DIR=./data/receipts

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SILENT=false

# Optional scheduler mode (checks every minute and runs once at target time)
SCHEDULE_ENABLED=false
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0
